# OpenClaw Deploy — example environment variables.
# Copy to .env.local for local dev. NEVER commit a real .env file.

# --- apps/api (control plane) ---
PORT=8787
DATABASE_URL=postgres://localhost:5432/openclaw_deploy
# Choose either local file vault or Hashicorp Vault / OpenBao.
VAULT_BACKEND=file
VAULT_FILE_PATH=./.vault.local.json
# VAULT_ADDR=https://vault.example.com
# VAULT_TOKEN=

# --- apps/landing (marketing site) ---
NEXT_PUBLIC_SITE_URL=https://openclaw-deploy.prin7r.com
NEXT_PUBLIC_GITHUB_URL=https://github.com/prin7r-projects/openclaw-deploy

# --- reconciler tunables (used by future control plane) ---
RECONCILE_INTERVAL_SECONDS=5
ROTATE_KEYS_CONCURRENCY=1
